{
  "name": "@ipcora/core",
  "version": "0.3.0",
  "description": "Transport-agnostic typed IPC router for TypeScript.",
  "homepage": "https://github.com/YanChenBai/ipcora#readme",
  "bugs": {
    "url": "https://github.com/YanChenBai/ipcora/issues"
  },
  "license": "MIT",
  "author": "YanChenBai <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YanChenBai/ipcora.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "tsc --noEmit",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "arktype": "^2.2.0",
    "pika-events": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
